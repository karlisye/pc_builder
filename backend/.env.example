APP_NAME=DatorBuve
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pc_builder
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Add localhost:5173 if using the Vite dev server
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:3000,localhost:8000,127.0.0.1,127.0.0.1:8000,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local dev: Mailpit (see docker-compose.yml) — no auth needed, view sent mail at http://localhost:8025
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@pcbuilder.lv"
MAIL_FROM_NAME="${APP_NAME}"

# Production: set MAIL_MAILER=resend and RESEND_API_KEY
RESEND_API_KEY=

# Cloudflare Turnstile — create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# (add localhost for local dev). Leave TURNSTILE_SECRET_KEY blank to skip
# verification entirely (local dev/tests).
TURNSTILE_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
