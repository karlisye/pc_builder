# Production env template — copy to /opt/datorbuve/.env.production on the
# server and fill in the secrets. Never commit the real file.
APP_NAME=DatorBuve
APP_ENV=production
APP_KEY=            # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://datorbuve.lv
FRONTEND_URL=https://datorbuve.lv

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pc_builder
DB_USERNAME=sail
DB_PASSWORD=        # strong random password — also used by the mysql container

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=datorbuve.lv

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@datorbuve.lv"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=     # from resend.com — domain datorbuve.lv must be verified there

# Production Turnstile widget for datorbuve.lv (the dev widget only allows localhost)
TURNSTILE_SECRET_KEY=

TELESCOPE_ENABLED=false
